# eyegents Environment Variables
# Copy to .env and fill in values

# GitHub (required for MCP GitHub tools)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=pablo
GITHUB_REPO=eyegents

# Qdrant (optional API key for cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Ollama
OLLAMA_URL=http://localhost:11434/v1

# External Fallback Providers (optional)
OPENCODE_ZEN_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Logging
LOG_LEVEL=warn

# Model Configuration
EMBEDDING_MODEL=bge-m3:latest
BATCH_SIZE=32
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP=50
WATCH_MODE=false