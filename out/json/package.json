{
  "name": "eyegents",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/agent-runtime",
    "packages/context-engine",
    "packages/github-client",
    "packages/mcp-client",
    "mcp-server",
    "packages/ollama-client",
    "packages/qdrant-client",
    "packages/shared-types",
    "vector-index"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:push": "turbo run db:push",
    "index": "docker compose -f docker/docker-compose.yml --profile indexing up indexer"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "@biomejs/biome": "^1.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.0"
}
