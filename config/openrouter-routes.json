{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Agent-to-model routing rules for OpenRouter integration",
  "version": "0.2.0",
  "models": {
    "qwen-coder": {
      "openrouterId": "qwen/qwen3-coder:free",
      "contextWindow": 1048576,
      "maxOutput": 16384,
      "costPerMillionInput": 0,
      "costPerMillionOutput": 0,
      "strengths": ["coding", "code generation", "refactoring", "agent orchestration"],
      "tier": "free"
    },
    "deepseek-flash-free": {
      "openrouterId": "deepseek/deepseek-v4-flash:free",
      "contextWindow": 1048576,
      "maxOutput": 16384,
      "costPerMillionInput": 0,
      "costPerMillionOutput": 0,
      "strengths": ["long context", "fast coding", "complex tasks"],
      "tier": "free"
    },
    "openrouter-free": {
      "openrouterId": "openrouter/free",
      "contextWindow": 0,
      "maxOutput": 0,
      "costPerMillionInput": 0,
      "costPerMillionOutput": 0,
      "strengths": ["general fallback", "model routing"],
      "tier": "free"
    },
    "nemotron-ultra": {
      "openrouterId": "nvidia/nemotron-3-ultra-550b-a55b",
      "contextWindow": 1048576,
      "maxOutput": 16384,
      "costPerMillionInput": 0.001,
      "costPerMillionOutput": 0.003,
      "strengths": ["complex reasoning", "security audits", "architecture review"],
      "tier": "paid"
    },
    "deepseek-pro": {
      "openrouterId": "deepseek/deepseek-v4-pro",
      "contextWindow": 1048576,
      "maxOutput": 16384,
      "costPerMillionInput": 0.435,
      "costPerMillionOutput": 0.87,
      "strengths": ["complex reasoning", "architecture", "deep analysis"],
      "tier": "paid"
    }
  },
  "agentRoutes": {
    "orchestrator": {
      "simple": {
        "model": "local",
        "description": "Use local qwen2.5-coder:7b for simple orchestration tasks"
      },
      "complex": {
        "model": "qwen-coder",
        "description": "Qwen3 Coder for complex multi-step planning and routing"
      },
      "complexityThreshold": 2048,
      "complexKeywords": ["decompose", "plan", "architecture", "refactor", "multi-step", "break down", "coordinate"]
    },
    "backend": {
      "primary": {
        "model": "qwen-coder",
        "description": "Qwen3 Coder for backend coding tasks"
      },
      "fallback": {
        "model": "deepseek-flash-free",
        "description": "DeepSeek V4 Flash (free) as long-context fallback"
      }
    },
    "frontend": {
      "primary": {
        "model": "qwen-coder",
        "description": "Qwen3 Coder for frontend tasks"
      },
      "fallback": {
        "model": "deepseek-flash-free",
        "description": "DeepSeek V4 Flash (free) as fallback"
      }
    },
    "qa": {
      "primary": {
        "model": "qwen-coder",
        "description": "Qwen3 Coder for test generation"
      },
      "fallback": {
        "model": "deepseek-flash-free",
        "description": "DeepSeek V4 Flash (free) as fallback"
      }
    },
    "ops": {
      "primary": {
        "model": "qwen-coder",
        "description": "Qwen3 Coder for ops tasks"
      },
      "fallback": {
        "model": "deepseek-flash-free",
        "description": "DeepSeek V4 Flash (free) as fallback"
      }
    },
    "fullstack": {
      "primary": {
        "model": "qwen-coder",
        "description": "Qwen3 Coder for full-stack features"
      },
      "fallback": {
        "model": "deepseek-flash-free",
        "description": "DeepSeek V4 Flash (free) as fallback"
      }
    },
    "certifier": {
      "primary": {
        "model": "nemotron-ultra",
        "description": "Nemotron 3 Ultra for security audits and compliance"
      },
      "fallback": {
        "model": "deepseek-pro",
        "description": "DeepSeek V4 Pro as secondary option"
      }
    },
    "aider": {
      "primary": {
        "model": "qwen-coder",
        "description": "Qwen3 Coder as default for Aider coding tasks"
      },
      "fallback": {
        "model": "deepseek-flash-free",
        "description": "DeepSeek V4 Flash (free) as long-context fallback for Aider"
      },
      "general": {
        "model": "openrouter-free",
        "description": "OpenRouter free routing as general fallback"
      }
    }
  },
  "localModels": {
    "primary": "qwen2.5-coder:7b",
    "small": "qwen2.5:0.5b",
    "embedding": "bge-m3:latest"
  }
}
