# OpenRouter Configuration — Isolated from main eyegents config
# API keys are stored in .secrets (gitignored)
# Source this file: source scripts/load-secrets.sh

# API Keys — loaded from .secrets file
# OPENROUTER_API_KEY=<from .secrets>
# GH_PAT=<from .secrets>

# OpenRouter Model IDs
NEMOTRON_SUPER=nvidia/nemotron-3-super-120b-a12b:free
NEMOTRON_ULTRA=nvidia/nemotron-3-ultra-550b-a55b
NEMOTRON_NANO=nvidia/nemotron-3-nano-30b-a3b:free
DEEPSEEK_FLASH=deepseek/deepseek-v4-flash
DEEPSEEK_PRO=deepseek/deepseek-v4-pro

# OpenRouter Metadata
OPENROUTER_SITE_URL=https://github.com/browneyes-sec/eyegents
OPENROUTER_SITE_TITLE=eyegents

# Default Model (used if no route match)
OPENROUTER_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Rate Limiting
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_DELAY_MS=1000
