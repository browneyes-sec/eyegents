    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@eyegents/shared-types": "*",
    "@eyegents/openrouter-client": "*",
    "@eyegents/qdrant-client": "*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
